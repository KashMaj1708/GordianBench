+// replicaCaughtUp reports whether the replica has replayed WAL up to at least
+// want. The second return value is false if we could not determine the replica
+// position (in which case the caller should conservatively use the primary).
+func (s *server) replicaCaughtUp(want uint64) (caught bool, known bool) {
+	var replayText sql.NullString
+	// On a streaming replica pg_last_wal_replay_lsn() returns the last applied
+	// position. On a non-replica it returns NULL, in which case the replica is
+	// effectively as current as the primary.
+	err := s.replica.QueryRow("SELECT pg_last_wal_replay_lsn()::text").Scan(&replayText)
+	if err != nil {
+		return false, false
+	}
+	if !replayText.Valid {
+		// Not in recovery: treat as fully caught up.
+		return true, true
+	}
+	replay, ok := parseLSN(replayText.String)
+	if !ok {
+		return false, false
+	}
+	return replay >= want, true
+}
+
 func readBalance(db *sql.DB, account string) (int64, error) {
 	var balance int64
 	err := db.QueryRow("SELECT balance_cents FROM accounts WHERE id = $1", account).Scan(&balance)
 	return balance, err
 }
 
+// parseLSN converts a Postgres LSN string ("X/Y", both hex) to a comparable
+// 64-bit value.
+func parseLSN(s string) (uint64, bool) {
+	for i := 0; i < len(s); i++ {
+		if s[i] == '/' {
+			hi, err1 := strconv.ParseUint(s[:i], 16, 64)
+			lo, err2 := strconv.ParseUint(s[i+1:], 16, 64)
+			if err1 != nil || err2 != nil {
+				return 0, false
+			}
+			return (hi << 32) | lo, true
+		}
+	}
+	return 0, false
+}
