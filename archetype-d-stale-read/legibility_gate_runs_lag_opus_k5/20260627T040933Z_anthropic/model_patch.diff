+// mark records that account requires the replica to have replayed at least
+// `lsn` before a replica read can be considered consistent. Only advances the
+// watermark forward.
+func (w *writeWatermark) mark(primary *sql.DB, account, lsn string) {
+	if lsn == "" {
+		return
+	}
+	w.mu.Lock()
+	defer w.mu.Unlock()
+	cur, ok := w.lsn[account]
+	if !ok {
+		w.lsn[account] = lsn
+		return
+	}
+	// Keep the greater LSN.
+	if ahead, err := lsnGE(primary, lsn, cur); err == nil && ahead {
+		w.lsn[account] = lsn
+	}
+}
