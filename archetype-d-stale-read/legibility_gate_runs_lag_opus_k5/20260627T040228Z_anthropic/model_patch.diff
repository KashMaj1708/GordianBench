+}
+
+// clear removes the pin once the replica has caught up.
+func (p *readWritePin) clear(account string, expected int64) {
+	p.mu.Lock()
+	defer p.mu.Unlock()
+	// Only clear if it still matches what we observed; a newer write may have
+	// updated the expected value in the meantime.
+	if v, ok := p.lastVal[account]; ok && v == expected {
+		delete(p.lastVal, account)
+	}
 }
 
