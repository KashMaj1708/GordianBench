+// replicaCaughtUp reports whether the replica has replayed up to at least the
+// given primary LSN.
+func replicaCaughtUp(replica *sql.DB, requiredLSN string) (bool, error) {
+	var replayed sql.NullString
+	// On a standby, pg_last_wal_replay_lsn() returns the last replayed LSN.
+	if err := replica.QueryRow("SELECT pg_last_wal_replay_lsn()::text").Scan(&replayed); err != nil {
+		return false, err
+	}
+	if !replayed.Valid || replayed.String == "" {
+		return false, nil
+	}
+	var caught bool
+	if err := replica.QueryRow(
+		"SELECT $1::pg_lsn >= $2::pg_lsn", replayed.String, requiredLSN,
+	).Scan(&caught); err != nil {
+		return false, err
+	}
+	return caught, nil
+}
