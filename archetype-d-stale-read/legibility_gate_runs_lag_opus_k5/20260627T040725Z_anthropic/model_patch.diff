+// maybeReleasePin checks whether the replica has caught up to the primary value
+// for an account and, if so, releases the pin (provided no newer write has
+// occurred since the version we verified) so future reads can be served from the
+// replica again.
+func (s *server) maybeReleasePin(account string, verified uint64, primaryBalance int64) {
+	replicaBalance, err := readBalance(s.replica, account)
