+// waitForReplication polls the replica until it sees the expected balance for the account,
+// or until a timeout is reached.
+func (s *server) waitForReplication(account string, expectedBalance int64) error {
+	deadline := time.Now().Add(5 * time.Second)
+	for {
+		var replicaBalance int64
+		err := s.replica.QueryRow("SELECT balance_cents FROM accounts WHERE id = $1", account).Scan(&replicaBalance)
+		if err == nil && replicaBalance == expectedBalance {
+			return nil
+		}
+		if time.Now().After(deadline) {
+			return sql.ErrNoRows
+		}
+		time.Sleep(10 * time.Millisecond)
+	}
+}
