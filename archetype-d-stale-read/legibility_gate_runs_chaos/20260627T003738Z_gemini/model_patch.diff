 func newReadWritePin(ttl time.Duration) *readWritePin {
-	return &readWritePin{ttl: ttl, exp: make(map[string]time.Time)}
+	p := &readWritePin{ttl: ttl, exp: make(map[string]time.Time)}
+	go func() {
+		// Periodically clean up expired pins to prevent unbounded map growth, which
+		// can cause long GC pauses that in turn cause this read-after-write
+		// mechanism to fail.
+		for {
+			time.Sleep(ttl)
+			now := time.Now()
+			p.mu.Lock()
+			for account, exp := range p.exp {
+				if now.After(exp) {
+					delete(p.exp, account)
+				}
+			}
+			p.mu.Unlock()
+		}
+	}()
+	return p
 }
 
