+func (s *server) replicaSafeForAccount(account string) bool {
+	entry, pinned := s.pin.required(account)
+	if !pinned {
+		// This process might not have seen the preceding write (for example when
+		// there are multiple API instances), so do not assume an unpinned account is
+		// safe to read from a possibly lagging replica. Use the primary's current
+		// WAL location as a freshness barrier for the replica.
+		var lsn string
+		if err := s.primary.QueryRow("SELECT pg_current_wal_lsn()::text").Scan(&lsn); err != nil {
+			log.Printf("could not read primary WAL LSN before balance read for account %q: %v", account, err)
+			return false
+		}
+		pos, ok := parseLSN(lsn)
+		if !ok {
+			return false
+		}
+		entry = pinEntry{lsn: lsn, pos: pos}
+	}
+	if entry.lsn == "" {
+		return false
+	}
+
+	var caughtUp bool
+	err := s.replica.QueryRow(`
+		SELECT CASE
+			WHEN pg_is_in_recovery() THEN COALESCE(pg_last_wal_replay_lsn() >= $1::pg_lsn, false)
+			ELSE true
+		END`, entry.lsn).Scan(&caughtUp)
+	if err != nil || !caughtUp {
+		if err != nil {
+			log.Printf("could not check replica replay LSN for account %q: %v", account, err)
+		}
+		return false
+	}
+
+	if pinned {
+		s.pin.clear(account, entry.pos)
+	}
+	return true
+}
