+func readBalanceWithReplayState(db *sql.DB, account, requiredLSN string) (int64, string, bool, error) {
+	var balance int64
+	var replayedThrough string
+	var caughtUp bool
+	err := db.QueryRow(`
+		SELECT balance_cents,
+		       COALESCE(pg_last_wal_replay_lsn()::text, ''),
+		       COALESCE(pg_last_wal_replay_lsn() >= $2::pg_lsn, false)
+		FROM accounts
+		WHERE id = $1`, account, requiredLSN).Scan(&balance, &replayedThrough, &caughtUp)
+	return balance, replayedThrough, caughtUp, err
+}
