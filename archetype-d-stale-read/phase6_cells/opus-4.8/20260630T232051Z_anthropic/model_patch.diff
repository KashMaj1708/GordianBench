+// replicaCaughtUp reports whether the replica has replayed WAL up to (or past)
+// the given LSN.
+func replicaCaughtUp(replica *sql.DB, lsn string) (bool, error) {
+	var caughtUp sql.NullBool
+	err := replica.QueryRow(
+		"SELECT pg_last_wal_replay_lsn() >= $1::pg_lsn",
+		lsn,
+	).Scan(&caughtUp)
+	if err != nil {
+		return false, err
+	}
+	// On a non-replica (or when replay LSN is unknown) the result is NULL; treat
+	// that conservatively as "not caught up" so we keep serving from primary.
+	return caughtUp.Valid && caughtUp.Bool, nil
+}
