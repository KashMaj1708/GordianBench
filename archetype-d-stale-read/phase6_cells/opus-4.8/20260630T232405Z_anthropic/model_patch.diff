-	balance, err := readBalance(db, account)
-	if err != nil && source == "primary" {
-		// Primary read path unavailable; fall back to the replica.
+	// Read-after-write consistency: always serve balances from the primary,
+	// which is the authoritative, up-to-date source. The asynchronous replica
+	// can lag the primary by an unbounded amount (replication delay, network
+	// faults, etc.). A previous heuristic briefly "pinned" reads to the primary
+	// for a fixed time window after a write, then fell back to the replica.
+	// That was not safe: once the window elapsed, reads could be served from a
+	// replica that had not yet applied the write and would return a stale
+	// (pre-deposit) balance.
+	//
+	// The replica is used only as a best-effort fallback when the primary is
+	// unavailable; in that degraded mode the returned value may be stale.
+	source := "primary"
+	balance, err := readBalance(s.primary, account)
+	if err != nil {
 		source = "replica"
 		balance, err = readBalance(s.replica, account)
 	}
