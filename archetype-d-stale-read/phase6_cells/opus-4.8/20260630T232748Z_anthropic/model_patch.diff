+// replicaCaughtUp reports whether the replica has replayed WAL up to at least
+// the given LSN. If the status cannot be determined (e.g. the replica is the
+// primary, or the query errors) it conservatively returns false so reads stay
+// on the primary.
+func (s *server) replicaCaughtUp(lsn string) bool {
+	var caughtUp sql.NullBool
+	err := s.replica.QueryRow(
+		"SELECT pg_last_wal_replay_lsn() >= $1::pg_lsn", lsn,
+	).Scan(&caughtUp)
+	if err != nil {
+		return false
+	}
+	return caughtUp.Valid && caughtUp.Bool
