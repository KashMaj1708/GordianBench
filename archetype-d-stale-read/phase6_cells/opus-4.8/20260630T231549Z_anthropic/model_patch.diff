-	exp map[string]time.Time
+// writeWatermark implements read-after-write consistency in a way that is
+// robust to unbounded replication lag.
+//
+// The previous implementation pinned an account's reads to the primary for a
+// fixed time window (PIN_TTL_MS) after a write. That is unsafe: if replication
+// lag exceeds the TTL, the pin expires while the replica is still behind, and a
+// follow-up read served from the replica returns the stale (pre-deposit) value.
+//
+// Instead we remember, per account, the balance produced by the most recent
+// write we performed. Balances are monotonically non-decreasing per account
+// (deposits only add to the balance), so on a read we can decide whether the
+// replica has caught up by checking that its balance is at least the last value
+// we wrote. If the replica is still behind that watermark, we serve the read
+// from the primary instead. Correctness now depends on whether the replica has
+// actually replicated our write, not on a wall-clock guess.
+type writeWatermark struct {
+	mu      sync.Mutex
+	balance map[string]int64 // highest balance we have written for the account
 }
 
-func newReadWritePin(ttl time.Duration) *readWritePin {
-	return &readWritePin{ttl: ttl, exp: make(map[string]time.Time)}
+func newWriteWatermark() *writeWatermark {
+	return &writeWatermark{balance: make(map[string]int64)}
 }
 
-func (p *readWritePin) mark(account string) {
-	p.mu.Lock()
-	defer p.mu.Unlock()
-	p.exp[account] = time.Now().Add(p.ttl)
+// record stores the result of a write for an account, keeping the highest value.
+func (w *writeWatermark) record(account string, balance int64) {
+	w.mu.Lock()
+	defer w.mu.Unlock()
+	if cur, ok := w.balance[account]; !ok || balance > cur {
+		w.balance[account] = balance
+	}
 }
 
-func (p *readWritePin) pinned(account string) bool {
-	p.mu.Lock()
-	defer p.mu.Unlock()
-	exp, ok := p.exp[account]
-	return ok && time.Now().Before(exp)
+// watermark returns the highest balance we have written for the account and
+// whether we have any record for it.
+func (w *writeWatermark) watermark(account string) (balance int64, ok bool) {
+	w.mu.Lock()
+	defer w.mu.Unlock()
+	b, ok := w.balance[account]
+	return b, ok
 }
 
