+// extend extends the pin's expiration time for an account.
+func (p *readWritePin) extend(account string, duration time.Duration) {
+	p.mu.Lock()
+	defer p.mu.Unlock()
+	if exp, ok := p.exp[account]; ok {
+		newExp := exp.Add(duration)
+		p.exp[account] = newExp
+	}
+}
