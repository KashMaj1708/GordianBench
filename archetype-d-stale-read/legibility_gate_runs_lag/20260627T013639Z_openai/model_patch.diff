+// waitForReplica waits for the replica to reflect the expected balance for an account,
+// or returns after timeout.
+func (s *server) waitForReplica(account string, want int64, timeout time.Duration) {
+	deadline := time.Now().Add(timeout)
+	for time.Now().Before(deadline) {
+		balance, err := readBalance(s.replica, account)
+		if err == nil && balance == want {
+			return
+		}
+		time.Sleep(10 * time.Millisecond)
+	}
+}
